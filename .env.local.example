# ─── Firebase (Phone Auth) ───────────────────────────────────────────────────
# Client-side config — from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mooves-xxxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mooves-xxxxx

# Server-side Admin SDK — from Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → copy values from it
FIREBASE_PROJECT_ID=mooves-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mooves-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ─── Supabase JWT secret ──────────────────────────────────────────────────────
# Project Settings → API → JWT Settings → JWT Secret
# Used server-side to mint tokens that Supabase RLS trusts
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Inbound SMS only (SMS feed check feature, Screen 11).
# NOT used for auth OTP — Firebase handles that.
# SMS Feed Check: the Mooves number + credentials for the inbound webhook
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_SMS_NUMBER=+1xxxxxxxxxx   # The Mooves toll-free number (not the auth one)

# ─── PostHog ─────────────────────────────────────────────────────────────────
# Project Settings → Project API Key in PostHog dashboard
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://makemooves.app
# In development, use: http://localhost:3000
